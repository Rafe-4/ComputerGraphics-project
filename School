#include <GL/glut.h>
void display(){
glClear(GL_COLOR_BUFFER_BIT);
glColor3f(1,0,0);
glBegin(GL_QUADS);
glVertex2f(-0.6,-0.4);glVertex2f(0.6,-0.4);
glVertex2f(0.6,0.4);
glVertex2f(-0.6,0.4);
glEnd();
glFlush();
}
int main(int argc,char** argv){
glutInit(&argc,argv);
glutCreateWindow("School");
glutDisplayFunc(display);
glutMainLoop();
}

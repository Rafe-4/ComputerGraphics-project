#include <GL/glut.h>
void display(){
glClear(GL_COLOR_BUFFER_BIT);
// sky
glColor3f(0.5,0.8,1);
glBegin(GL_QUADS);
glVertex2f(-1,1);
glVertex2f(1,1);
glVertex2f(1,0);
glVertex2f(-1,0);
glEnd();
// ground
glColor3f(0,1,0);
glBegin(GL_QUADS);
glVertex2f(-1,0);
glVertex2f(1,0);
glVertex2f(1,-1);
glVertex2f(-1,-1);
glEnd();
glFlush();
}
int main(int argc,char** argv){
glutInit(&argc,argv);
glutCreateWindow("Final Scene");
glutDisplayFunc(display);
glutMainLoop();
}
